{
  "name": "@jackemcpherson/tipper",
  "version": "3.0.0",
  "description": "AFL match prediction CLI combining MOV-Elo with player-level PAV ratings",
  "license": "MIT",
  "author": "Jack McPherson <jackemcpherson@gmail.com>",
  "type": "module",
  "bin": {
    "tipper": "./dist/cli/index.js"
  },
  "files": [
    "dist/",
    "configs/**/config.json",
    "configs/_current.json",
    "README.md",
    "CHANGELOG.md",
    "LICENSE"
  ],
  "engines": {
    "node": ">=20"
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "dev": "wrangler dev",
    "build": "tsc",
    "test": "vitest",
    "check": "biome check .",
    "format": "biome format --write .",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "bun run typecheck && bun run build"
  },
  "dependencies": {
    "commander": "^13.0.0",
    "zod": "^3.24.0"
  },
  "devDependencies": {
    "@biomejs/biome": "^1.9.0",
    "@cloudflare/workers-types": "^4.20250419.0",
    "@types/node": "^25.6.0",
    "typescript": "^5.7.0",
    "vitest": "^3.1.0",
    "wrangler": "^4.14.0"
  }
}
