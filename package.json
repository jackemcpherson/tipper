{
  "name": "@jackemcpherson/tipper",
  "version": "3.4.0",
  "description": "AFL match prediction CLI combining MOV-Elo with player-level PAV ratings",
  "license": "MIT",
  "author": "Jack McPherson <jackemcpherson@gmail.com>",
  "type": "module",
  "bin": {
    "tipper": "./dist/cli/index.js"
  },
  "files": [
    "dist/",
    "configs/**/config.json",
    "configs/_current.json",
    "README.md",
    "CHANGELOG.md",
    "LICENSE"
  ],
  "engines": {
    "node": ">=20"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/jackemcpherson/tipper.git"
  },
  "homepage": "https://github.com/jackemcpherson/tipper#readme",
  "bugs": "https://github.com/jackemcpherson/tipper/issues",
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "bake-config": "bun scripts/bake-config.ts",
    "build": "tsc",
    "test": "vitest",
    "check": "biome check .",
    "format": "biome format --write .",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "bun run typecheck && bun run build"
  },
  "dependencies": {
    "commander": "15.0.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.9",
    "@cloudflare/workers-types": "^4.20250419.0",
    "@types/node": "^26.1.1",
    "typescript": "6.0.3",
    "vitest": "4.1.10",
    "wrangler": "^4.14.0"
  }
}
