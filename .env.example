# tipper environment variables — copy to .env (gitignored) and fill in.
# All four are optional: defaults come from the bundled config and from
# wrangler's OAuth token when `wrangler login` has been run.

# Cloudflare API token with D1 read access on the afl-stats database.
# Takes precedence over wrangler's OAuth token; required in CI / non-interactive
# environments where `wrangler login` isn't available.
CLOUDFLARE_API_TOKEN=

# Override the default Cloudflare account ID baked into the CLI. Point this at
# your own account when running tipper against your own afl-stats D1 copy.
CLOUDFLARE_ACCOUNT_ID=

# Override the default D1 database ID. Set when your afl-stats database has a
# different ID from the maintainer's.
CLOUDFLARE_D1_DATABASE_ID=

# Set to any non-empty value to disable the local season-data cache
# (~/.cache/tipper/). Useful when iterating on data ingestion.
TIPPER_NO_CACHE=
