{
  "id": "rtm-test-00",
  "schema_version": 1,
  "notes": "Task 6: RTM robustness. RTM=0.0 (v1 winner).",

  "elo": {
    "k": 25,
    "initial_rating": 1500,
    "home_advantage": 80,
    "regression_to_mean": 0.0,
    "mov_multiplier": "538_log"
  },

  "pav": {
    "computation": "round_by_round_cumulative",
    "prior_weight_k": 15,
    "prior_source": "previous_season_final",
    "missing_player_default": 5,
    "include": "named_lineup_excl_emerg"
  },

  "blend": {
    "weight_elo": 1.0,
    "pav_calibration_slope": 0.246,
    "where": "team_rating"
  },

  "output": {
    "margin_per_rating_point": 0.07,
    "sigma": 36
  },

  "backtest": {
    "train_seasons": [2020],
    "test_seasons": [2021, 2022, 2023, 2024, 2025, 2026],
    "walk_forward": true
  }
}
